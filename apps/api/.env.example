# Conexão com o PostgreSQL (casa com os defaults do docker-compose.yml na raiz)
# Use 127.0.0.1 (IPv4) em vez de "localhost": no Windows + Docker Desktop o
# "localhost" pode resolver para IPv6 (::1) e a conexão com o container expira.
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=alura
DB_PASSWORD=alura
DB_NAME=alura_auth

# Segredo de assinatura dos JWTs (defina um valor forte em produção)
JWT_SECRET=dev-secret
